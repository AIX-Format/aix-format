#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Schema-Type Drift Check (Optional Local Validation)
# يمكن تفعيله للتحقق المحلي قبل الـ commit

echo "🔍 Running Schema-Type drift check..."
npm run schema:sync:check --silent

if [ $? -ne 0 ]; then
  echo ""
  echo "⚠️  Schema-Type drift detected!"
  echo "⚠️  تم اكتشاف انحراف Schema-Type!"
  echo ""
  echo "Run 'npm run schema:sync:fix' to resolve."
  echo "قم بتشغيل 'npm run schema:sync:fix' للإصلاح."
  echo ""
  echo "Or commit with --no-verify to skip this check."
  echo "أو استخدم --no-verify لتجاوز هذا الفحص."
  exit 1
fi

echo "✅ Schema-Type sync verified"