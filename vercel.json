{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @aix/studio build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "apps/studio/.next",
  "functions": {},
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.axiomid.app"
        }
      ],
      "destination": "https://axiomid.app/$1",
      "permanent": true
    }
  ]
}
