{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axiomid.app/schemas/manifest.schema.json",
  "title": "AIX Manifest Validation Schema",
  "description": "Validation schema for manifest.json files, enforcing SHA-256 integrity and digital signatures under the Sovereign Protocol.",
  "type": "object",
  "required": ["version", "checksums", "signature"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Manifest format version.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "checksums": {
      "type": "object",
      "description": "Mapping of filenames to their SHA-256 checksums.",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-fA-F0-9]{64}$",
        "description": "SHA-256 hex hash."
      }
    },
    "signature": {
      "type": "object",
      "description": "Digital signature for the manifest content.",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["Ed25519", "secp256k1"],
          "description": "Cryptographic algorithm."
        },
        "value": {
          "type": "string",
          "description": "Base64url encoded signature."
        },
        "publicKey": {
          "type": "string",
          "description": "Base64url encoded public key (optional if resolvable via DID)."
        },
        "signer": {
          "type": "string",
          "description": "Signer identifier (AxiomID / DID)."
        }
      }
    }
  },
  "additionalProperties": false
}
