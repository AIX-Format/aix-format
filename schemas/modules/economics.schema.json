{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://amrikyy.ai/schemas/modules/economics.schema.json",
  "title": "AIX Economics Module",
  "type": "object",
  "properties": {
    "pi_smart_contract": {
      "type": "object",
      "description": "Pi Network Smart Contract interface for automated settlements",
      "required": [
        "address",
        "network"
      ],
      "properties": {
        "address": {
          "type": "string",
          "description": "Contract address on the Pi Network"
        },
        "network": {
          "type": "string",
          "enum": [
            "mainnet",
            "testnet",
            "sandbox"
          ]
        },
        "escrow_enabled": {
          "type": "boolean",
          "default": false
        },
        "abi_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "pricing": {
      "type": "object",
      "description": "Pricing model for agent usage (Legacy Pricing included in Economics Layer)",
      "properties": {
        "model": {
          "type": "string",
          "description": "Pricing model type",
          "enum": [
            "pay_per_call",
            "subscription",
            "freemium",
            "tiered"
          ],
          "default": "pay_per_call"
        },
        "cost_per_call": {
          "type": "object",
          "description": "Cost per API call",
          "properties": {
            "amount": {
              "type": "number",
              "description": "Cost amount",
              "minimum": 0
            },
            "currency": {
              "type": "string",
              "description": "Currency code (ISO 4217)",
              "default": "PI",
              "examples": [
                "PI",
                "SOL",
                "USD",
                "EUR"
              ]
            }
          }
        },
        "subscription": {
          "type": "object",
          "description": "Subscription pricing",
          "properties": {
            "monthly_fee": {
              "type": "object",
              "properties": {
                "amount": {
                  "type": "number",
                  "minimum": 0
                },
                "currency": {
                  "type": "string",
                  "default": "PI"
                }
              }
            },
            "included_calls": {
              "type": "integer",
              "description": "Number of calls included in subscription",
              "minimum": 0
            },
            "additional_call_cost": {
              "type": "object",
              "properties": {
                "amount": {
                  "type": "number",
                  "minimum": 0
                },
                "currency": {
                  "type": "string",
                  "default": "PI"
                }
              }
            }
          }
        },
        "tiered_pricing": {
          "type": "array",
          "description": "Tiered pricing based on usage",
          "items": {
            "type": "object",
            "properties": {
              "min_calls": {
                "type": "integer",
                "minimum": 0
              },
              "max_calls": {
                "type": "integer",
                "minimum": 0
              },
              "cost_per_call": {
                "type": "object",
                "properties": {
                  "amount": {
                    "type": "number",
                    "minimum": 0
                  },
                  "currency": {
                    "type": "string",
                    "default": "PI"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
