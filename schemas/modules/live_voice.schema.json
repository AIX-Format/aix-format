{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://amrikyy.ai/schemas/modules/live_voice.schema.json",
  "title": "AIX Live Voice Module",
  "type": "object",
  "required": [
    "enabled",
    "provider"
  ],
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": false
    },
    "provider": {
      "type": "string",
      "enum": [
        "openai-realtime",
        "hume",
        "elevenlabs",
        "generic"
      ],
      "description": "The live voice model provider."
    },
    "voice_id": {
      "type": "string",
      "description": "The specific voice profile or identifier to use."
    },
    "latency_mode": {
      "type": "string",
      "enum": [
        "ultra_low",
        "standard",
        "high_quality"
      ],
      "default": "standard"
    }
  },
  "additionalProperties": true
}
