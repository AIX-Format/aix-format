# ============================================================
# AIX Format — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── 🔴 CRITICAL (app won't work without these) ──────────────

# Upstash Redis — storage, sessions, pulse stream, registry
# Get from: https://upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy aliases (for backward compatibility)
KV_REST_API_URL=https://your-redis-instance.upstash.io
KV_REST_API_TOKEN=your_redis_token_here

# ── 🟡 IMPORTANT (features disabled without these) ──────────

# Pi Network — Authentication & Payments
# Get from: https://develop.pi → Create App → Get API Key
# Domain must be verified in Pi Developer Portal
PI_API_KEY=your_pi_api_key_here
PI_APP_ID=your_pi_app_id
PI_ENVIRONMENT=sandbox  # or 'production'
NEXT_PUBLIC_PI_APP_ID=your_pi_app_id
NEXT_PUBLIC_PI_ENABLED=true

# Voice Services (for Voice Wizard)
# Groq — Voice STT (Whisper large-v3, free tier available)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key

# Google Gemini — Voice Wizard chat (Gemini 2.0 Flash)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIza_your_google_key

# xAI Grok — Global Voice Command intelligence
# Get from: https://console.x.ai
XAI_API_KEY=xai-your_grok_key

# ── 🟢 OPTIONAL (AI Services) ────────────────────────────────

# OpenAI (for embeddings, semantic memory)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI (optional, different from Gemini above)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ── 🔵 PAYMENTS & INTEGRATIONS ───────────────────────────────

# Telegram — Agent channel integration
# Get from: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Stripe — Payments
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# WalletConnect — wagmi wallet integration
# Get from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Crypto Payments
NEXT_PUBLIC_CRYPTO_ENABLED=false
PROTOCOL_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# ── 🔐 SECURITY & IDENTITY ───────────────────────────────────

# AIX Identity Layer — Salt for privacy-preserving UID hashing
# CRITICAL: Change this in production to a random secure value
AIX_UID_HASH_SALT=your_random_salt_here_change_in_production

# JWT Authentication Secret
# CRITICAL: Change this in production to a random secure value
JWT_SECRET=your_jwt_secret_change_in_production

# AxiomID — DID verification authority
AXIOM_AUTHORITY=axiomid.app
AXIOM_API_KEY=your_axiom_api_key_here

# ZK-KYC Verification Key (JSON string)
ZK_VERIFICATION_KEY={"your":"verification","key":"here"}

# ── ⚙️ APP CONFIGURATION ─────────────────────────────────────

# Next.js / App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=your-app.vercel.app
NEXT_PUBLIC_STUDIO_VERSION=1.3.0
NEXT_PUBLIC_LOG_LEVEL=info  # debug | info | warn | error

# Node Environment
NODE_ENV=development  # development | production | test

# ── 🛠️ SWARM ROUTER (Go Backend) ─────────────────────────────

# Swarm Router HTTP server port
SWARM_ROUTER_PORT=8080

# ── 📊 MONITORING & DEBUGGING ────────────────────────────────

# Sentry (optional, for error tracking)
SENTRY_DSN=your_sentry_dsn_here

# Enable debug logging
DEBUG=false

# Skip signature verification (NEVER use in production)
SKIP_SIGNATURE_VERIFICATION=false

# Bundle analyzer
ANALYZE=false

# ── 🚀 VERCEL CI (set in GitHub Secrets, not .env) ───────────
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_org_id
# VERCEL_PROJECT_ID=your_project_id