{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Schema-Type Sync Configuration",
  "description": "تكوين نظام مزامنة Schema-Type للكشف عن الانحراف",
  "version": "1.0.0",
  
  "ignore_patterns": [
    "*.test.ts",
    "*.spec.ts",
    "**/__tests__/**",
    "**/node_modules/**"
  ],
  
  "custom_type_mappings": {
    "ISODateTime": "string",
    "SemVer": "string",
    "AxiomDID": "string",
    "KycTier": "'anonymous' | 'basic' | 'verified' | 'sovereign' | 'institutional'",
    "DeadHandStatus": "'dormant' | 'active' | 'triggered'",
    "ArbitrageStrategy": "'route_splitting' | 'timing_attack' | 'skill_staking'"
  },
  
  "validation_rules": {
    "require_descriptions": true,
    "enforce_required_fields": true,
    "allow_additional_properties": false,
    "strict_type_matching": true
  },
  
  "notification_config": {
    "enabled": true,
    "channels": {
      "slack": {
        "enabled": false,
        "webhook_url": "${SLACK_WEBHOOK_URL}",
        "channel": "#aix-ci-alerts"
      },
      "discord": {
        "enabled": false,
        "webhook_url": "${DISCORD_WEBHOOK_URL}"
      },
      "email": {
        "enabled": false,
        "recipients": ["amrikyy@gmail.com"]
      }
    }
  },
  
  "ci_config": {
    "fail_on_drift": true,
    "generate_artifacts": true,
    "artifact_retention_days": 7,
    "run_on_branches": ["main", "develop"],
    "run_on_pr": true
  },
  
  "output": {
    "report_format": "markdown",
    "include_suggestions": true,
    "verbose": true,
    "color_output": true
  }
}