{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "declarationDir": "./types",
    "outDir": "./dist",
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "baseUrl": ".",
    "paths": {
      "../types/aix": ["./types/aix.d.ts"]
    }
  },
  "include": ["core/**/*.ts"],
  "exclude": ["node_modules", "dist", "apps", "tests"]
}
